# Copy to .env (or set as real env vars) before running with NODE_ENV=production.
# .env is gitignored — never commit real secrets.

# Required in production. Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Optional. Defaults to 3001.
PORT=3001

# Optional. Set to "production" to enable strict mode (refuses default JWT_SECRET).
NODE_ENV=production
